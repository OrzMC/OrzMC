# 基础环境
TZ=Asia/Shanghai
DATA_ROOT=/srv/orzmc
CADDY_EMAIL=admin@example.com

# 对外入口与域名
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
DOMAIN_QQBOT=qqbot.example.com
DOMAIN_QQBOT_API=api.qqbot.example.com
DOMAIN_QQBOT_WS=ws.qqbot.example.com
DOMAIN_MCS_WEB=mcs.example.com
DOMAIN_MCS_NODE=node.mcs.example.com

# MCSManager 端口
MCS_WEB_PORT=23333
MCS_DAEMON_PORT=24444

# NapCat 端口与运行用户
NAPCAT_HTTP_PORT=3000
NAPCAT_WS_PORT=3001
NAPCAT_WEBUI_PORT=6099
NAPCAT_UID=1000
NAPCAT_GID=1000

# QQ Bot 联调脚本
QQBOT_APP_ID=your_app_id_here
QQBOT_CLIENT_SECRET=your_client_secret_here
QQBOT_GUILD_ID=4678868088901888449
QQBOT_CHANNEL_ID=716172984
QQBOT_DM_GUILD_ID=4678868088901888449
QQBOT_PRIVATE_USER_ID=1F57730D6ADC5F5CD417D5614A52F2CF
QQBOT_MEMBER_LIMIT=20
QQBOT_TEST_MESSAGE=hello from qq bot

# PaperMC 最小模板
PAPERMC_IMAGE_NAME=your-papermc-image:1.21.1
PAPERMC_INSTANCE_NAME=papermc-main
PAPERMC_DISPLAY_NAME=OrzMC Main
PAPERMC_SERVER_PORT=25565
PAPERMC_PUBLISH_PORT=25565:25565
PAPERMC_SERVER_DIR=/srv/orzmc/instances/papermc-main/server
PAPERMC_LOG_DIR=/srv/orzmc/instances/papermc-main/server/logs
PAPERMC_PLUGIN_DIR=/srv/orzmc/instances/papermc-main/server/plugins
PAPERMC_MOUNT_SERVER_DIR=/srv/orzmc/instances/papermc-main/server:/server
PAPERMC_JAVA_VERSION=21
PAPERMC_MEMORY_MIN=2G
PAPERMC_MEMORY_MAX=4G
PAPERMC_JVM_OPTS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled
PAPERMC_STARTUP_COMMAND=java ${PAPERMC_JVM_OPTS} -Xms${PAPERMC_MEMORY_MIN} -Xmx${PAPERMC_MEMORY_MAX} -jar paper.jar --nogui
PAPERMC_MC_VERSION=1.21.1
PAPERMC_BUILD=latest
PAPERMC_SERVER_JAR_NAME=paper.jar
PAPERMC_EULA=true
PAPERMC_ONLINE_MODE=true
PAPERMC_MOTD=OrzMC Survival Server
PAPERMC_MAX_PLAYERS=20
PAPERMC_AUTO_RESTART=true
